<!DOCTYPE html>
<html>
<head>
  <title>Available Scans</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <h2>Available Scans</h2>
  {{if not .Scans}}
    <p>No files found in the directory.</p>
  {{else}}
    <ul>
      {{range .Scans}}
        <li>
          <button type="button" class="delete" onclick="deleteFile('{{.Name}}', '{{timeAgo .Time timeNow}}')">&#128465;</button>
          <a href="/download/{{.Name}}">&#128196; {{humanSize .Size}}</a>
          <span>{{timeAgo .Time timeNow}} ago</span>
        </li>
      {{end}}
    </ul>
  {{end}}
  <script>
    function deleteFile(name, timeAgo) {
      if (!confirm('Delete this scan from ' + timeAgo + ' ago?')) return;
      fetch('/download/' + encodeURIComponent(name), { method: 'DELETE' })
        .then(function (res) {
          if (res.ok) {
            location.reload();
          } else {
            alert('Delete failed.');
          }
        })
        .catch(function () {
          alert('Delete failed.');
        });
    }
  </script>
</body>
</html>
