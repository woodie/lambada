[Unit]
Description=Lambada MTA (SMTP scan exporter)
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/workspace/lambada
ExecStart=/home/pi/workspace/lambada/lambada-mta
Restart=always
# Matching lambada-web.service's LimitNOFILE for consistency.
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
